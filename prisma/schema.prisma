// Minimal schema for backoffice-ui. Extend with your full Supabase/Postgres models.
// https://pris.ly/d/prisma-schema-reference

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  BUY
  SELL
  TRANSFER
  REQUEST
  CLAIM
}

enum TransactionStatus {
  ACTIVE
  PENDING
  COMPLETED
  CANCELLED
  FAILED
}

enum PaymentProvider {
  NONE
  ANY
  SQUID
  LIFI
  PAYSTACK
}

enum SupportedChain {
  ETHEREUM
  BNB
  BASE
}

model User {
  id           String        @id @default(uuid())
  email        String?       @unique
  address      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model Transaction {
  id            String            @id @default(uuid())
  type          TransactionType
  status        TransactionStatus
  fromAmount    String
  toAmount      String
  provider      PaymentProvider
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  userId        String?
  user          User?             @relation(fields: [userId], references: [id])
}

model InventoryAsset {
  id        String   @id @default(uuid())
  chain     SupportedChain
  token     String
  balance   String
  updatedAt DateTime @updatedAt
}

model InventoryHistory {
  id        String         @id @default(uuid())
  assetId   String
  balance   String
  recordedAt DateTime     @default(now())
}
